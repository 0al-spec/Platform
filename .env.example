# Copy to .env and adjust for your machine before running platform deploy.

ORG_ROOT=/absolute/path/to/0AL
COMPOSE_PROJECT_NAME=0al-platform

SPECPM_IMAGE=python:3.12-slim
SPECSPACE_API_IMAGE=python:3.12-slim
SPECSPACE_WEB_IMAGE=node:18-bookworm-slim

SPECPM_INDEX_PORT=8081
SPECSPACE_API_PORT=8001
SPECSPACE_WEB_PORT=5173
SPECSPACE_DIALOG_DIR=/data/dialogs
SPECSPACE_API_HOST=127.0.0.1

# Required only by `deploy --profile hosted-managed`. Store secret values in
# untracked files with restrictive permissions; do not put them in this env file.
PLATFORM_MANAGED_OPERATION_TOKEN_FILE=/absolute/path/to/secrets/managed-operation-token
PLATFORM_MANAGED_OPERATION_DB_PASSWORD_FILE=/absolute/path/to/secrets/managed-operation-db-password
# Required by the hosted profile; begin production canaries read-only.
PLATFORM_MANAGED_OPERATION_ALLOWLIST=review_status_execute
PLATFORM_MANAGED_OPERATION_DB=managed_operations
PLATFORM_MANAGED_OPERATION_DB_USER=managed_operations
